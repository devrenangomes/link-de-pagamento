# Credenciais da API Efí Bank
EFI_CLIENT_ID=seu_client_id
EFI_CLIENT_SECRET=seu_client_secret

# Chave PIX para recebimento (CPF, CNPJ, e-mail, telefone ou chave aleatória)
EFI_PIX_KEY=sua_chave_pix

# Caminho para o certificado .p12 gerado no painel Efí Bank
# Painel > API > Meus Certificados > Criar Certificado
EFI_CERT_PATH=./certificados/certificado.p12
EFI_CERT_PASSPHRASE=

# true = ambiente de homologação (sandbox), false = produção
EFI_SANDBOX=true

# Nome do evento exibido nas páginas
EVENTO_NOME=Festa Junina 2025

PORT=3000
